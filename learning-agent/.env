# LLM 配置

# 使用本地 LLM（true/false）
USE_LOCAL_LLM=true

# 本地 LLM 服务配置
LOCAL_LLM_BASE_URL=http://127.0.0.1:15731/v1
LOCAL_LLM_API_KEY=sk-synapse-proxy
LOCAL_LLM_MODEL=gpt-5.4

# 如果用远程 OpenAI（需要设置 USE_LOCAL_LLM=false）
# OPENAI_API_KEY=sk-...
# MODEL_NAME=gpt-3.5-turbo

# 如果用 Anthropic Claude（需要设置 USE_LOCAL_LLM=false）
# ANTHROPIC_API_KEY=sk-ant-...
# MODEL_NAME=claude-opus-4-5-20251101
